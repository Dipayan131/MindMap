# --- FastAPI backend ---
# Recommended local dev: use Next.js proxy (no CORS setup). Do not set NEXT_PUBLIC_API_URL.
# next.config.ts forwards /api/* and /health to BACKEND_URL.
BACKEND_URL=http://127.0.0.1:8000

# Optional: call FastAPI directly from the browser (then set CORS_ORIGINS on the backend for http://localhost:3000)
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Firebase (Authentication — enable Email/Password + Google in Firebase Console)
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=
