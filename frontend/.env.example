# FastAPI backend (no trailing slash)
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Base URL of the auth service (no trailing slash). Your teammate implements these routes.
NEXT_PUBLIC_AUTH_API_BASE_URL=http://127.0.0.1:8001

# Optional overrides (must start with /)
# NEXT_PUBLIC_AUTH_LOGIN_PATH=/auth/login
# NEXT_PUBLIC_AUTH_REGISTER_PATH=/auth/register
